# Public frontend Supabase config. These VITE values are safe for the browser.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# Backend-only OpenAI key. Never expose this as VITE_OPENAI_API_KEY.
OPENAI_API_KEY=your-backend-openai-api-key

# Optional backend-only AI provider switch.
# Use "bedrock" to call Amazon Bedrock, or "openai" to force OpenAI.
AI_PROVIDER=openai

# Backend-only Amazon Bedrock API key. Never expose this as VITE_BEDROCK_API_KEY.
# Amazon Bedrock also recognizes this exact variable name.
AWS_BEARER_TOKEN_BEDROCK=your-backend-bedrock-api-key
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
